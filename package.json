    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.101.0",
    "@trigger.dev/sdk": "^4.4.6",
    "@turf/bbox": "^7.3.5",
    "@turf/center": "^7.3.5",
