{
  "name": "aim-apps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names TRIGGER,AIM_APP --prefix-colors magenta,cyan --timestamp-format \"HH:mm:ss\" --prefix \"[{name}: {time}]\" \"npm run dev:trigger\" \"npm run dev:local\"",
    "dev:local": "scripts/dev-local.sh",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:6060/api/inngest",
    "tunnel": "scripts/cloudflared-tunnel.sh",
    "dev:tunnel": "scripts/dev-with-supabase-tunnel.sh",
    "dev:trigger": "npx trigger.dev@latest dev",
    "dev:tours": "concurrently --kill-others --names TRIGGER,AIM_APP --prefix-colors magenta,cyan --timestamp-format \"HH:mm:ss\" --prefix \"[{name}: {time}]\" \"npm run dev:trigger\" \"npm run dev:tunnel\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.73",
