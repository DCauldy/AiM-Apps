# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI Configuration
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
# Recommended: gpt-4o (best balance of power and cost)
# Alternatives: gpt-4o-mini (very cost-effective), gpt-4-turbo (more expensive)
OPENAI_MODEL=gpt-4o-mini

# App Configuration (optional - defaults shown)
NEXT_PUBLIC_APP_URL=http://localhost:6060

# Blog Engine
# Enable Blog Engine feature
NEXT_PUBLIC_ENABLE_BLOG_ENGINE=false

# Radar
# Enable Radar feature
NEXT_PUBLIC_ENABLE_RADAR=false
# Browserless.io for web scraping (Google AI Overviews, Copilot, etc.)
BROWSERLESS_API_KEY=
BROWSERLESS_API_URL=https://chrome.browserless.io
# 32-byte hex key for encrypting CMS credentials (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BLOG_ENGINE_ENCRYPTION_KEY=
# Anthropic API key for Claude Sonnet (blog writing)
ANTHROPIC_API_KEY=
# Perplexity API key for Sonar Pro (topic research) — used when OPENROUTER_API_KEY is not set
PERPLEXITY_API_KEY=