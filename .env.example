# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── AiM WordPress Integration ───────────────────────────────────────────────
# Shared HMAC-SHA256 secret — must match AIM_APP_TOKEN_SECRET on the WP server
AIM_APP_TOKEN_SECRET=your_shared_secret_here

# Base URL of the WordPress site (used for redirects when unauthenticated)
NEXT_PUBLIC_AIM_BASE_URL=https://aimarketingacademy.com

# URL users go to when they hit their monthly limit and want to upgrade
NEXT_PUBLIC_AIM_UPGRADE_URL=https://aimarketingacademy.com?aim_modal=upgrade

# ─── Memberstack (AiM member login) ─────────────────────────────────────────
NEXT_PUBLIC_MEMBERSTACK_APP_ID=your_memberstack_app_id_here

# ─── Cloudflare Turnstile (bot protection on signup) ────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# ─── Stripe (prompt packs — feature-flagged) ───────────────────────────────
NEXT_PUBLIC_ENABLE_PROMPT_PACKS=false
STRIPE_SECRET_KEY=sk_your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://apps.aimarketingacademy.com
